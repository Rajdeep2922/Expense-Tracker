# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Paste your Atlas URI here, or use a local MongoDB URI:
#   Local:  mongodb://localhost:27017/expense_tracker
#   Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/expense_tracker
MONGODB_URI=

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins (leave * for open dev)
CORS_ORIGINS=*
